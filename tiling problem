class GFG {
    static int numberOfWays(int n) {
      
        if (n < 0) return 0;
        if (n == 0) return 1;
        int res = 0;
        
        res = numberOfWays(n - 1);
        res += numberOfWays(n - 2);
        
        return res;
    }

    public static void main(String[] args) {
        int n = 4;
        System.out.println(numberOfWays(n));
    }
}
